@startuml DS_ConsultationIA
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequence {
  ArrowColor #1565C0
  ArrowThickness 1.2
  ActorBorderColor #E65100
  ActorBackgroundColor #FFF3E0
  ActorFontStyle bold
  LifeLineBorderColor #757575
  ParticipantBorderColor #1565C0
  ParticipantBackgroundColor #E3F2FD
  ParticipantFontStyle bold
}

title <b>Diagramme de Séquence — Ajouter une Consultation avec Prédiction IA</b>

actor "Médecin" as Med
boundary "Interface (Consultation)" as UI
control "ConsultationController" as Ctrl
control "PredictionService" as Serv
boundary "Microservice IA\n(Python / FastAPI)" as API
entity "Base de Données" as DB

Med -> UI : Saisir symptômes et diagnostic
UI -> Ctrl : POST /consultation (données)
Ctrl -> DB : save(Consultation)
DB --> Ctrl : Consultation enregistrée
Ctrl --> UI : 201 Created

Med -> UI : Cliquer "Lancer prédiction IA"
UI -> Ctrl : POST /prediction/{consultationId}
Ctrl -> Serv : analyserRisque(donnéesPatient)
Serv -> API : POST /predict (JSON)

alt Service IA disponible
    API --> Serv : Résultat (score, recommandations)
    Serv -> DB : save(PredictionIA)
    DB --> Serv : Prédiction enregistrée
    Serv --> Ctrl : Résultat IA
    Ctrl --> UI : 200 OK
    UI --> Med : Afficher risque et recommandations
else Service IA indisponible
    API --> Serv : Erreur / Timeout
    Serv --> Ctrl : Exception (IA indisponible)
    Ctrl --> UI : 503 Service Unavailable
    UI --> Med : "Service IA temporairement indisponible"
end

@enduml